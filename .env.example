# これはテンプレート。実際の .env はコミットされない（.gitignore 済み）。
# ローカル実行時: az login すれば下記だけで動く（API_KEY不要）。
AZURE_OPENAI_ENDPOINT=https://snboku-0401-resource.cognitiveservices.azure.com
AZURE_MODEL_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_API_VERSION=preview

# 検索: Tavily（https://app.tavily.com で無料取得、クレカ不要）
TAVILY_API_KEY=tvly-xxxxxxxx

# GitHub Actions では下記を「GitHub Secrets」に登録する（.env には書かない）:
#   AZURE_CLIENT_ID / AZURE_CLIENT_SECRET / AZURE_TENANT_ID / TAVILY_API_KEY
# キー類は会話やコードに貼らず、GitHubのSecrets画面に直接入力すること。
