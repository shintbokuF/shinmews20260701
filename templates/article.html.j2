{%- set ICONS = {
  "chip": '<path d="M8 3v3M12 3v3M16 3v3M8 18v3M12 18v3M16 18v3M3 8h3M3 12h3M3 16h3M18 8h3M18 12h3M18 16h3"/><rect x="6" y="6" width="12" height="12" rx="1.5"/><rect x="9.5" y="9.5" width="5" height="5" rx=".8"/>',
  "cloud": '<path d="M7 18h9a4 4 0 0 0 .5-7.97A5.5 5.5 0 0 0 6 9.5 3.5 3.5 0 0 0 7 18Z"/><path d="M10 13.5h2M12 13.5v2"/>',
  "terminal": '<rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 9l3 3-3 3M13 15h4"/>',
  "torii": '<path d="M3 7h18M4.5 10h15M7 7v12M17 7v12M6 7c1.5-2.5 10.5-2.5 12 0"/>',
  "globe": '<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3v18M12 3c3 3 3 15 0 18M12 3c-3 3-3 15 0 18M4.5 7.5c4.5 2.5 10.5 2.5 15 0M4.5 16.5c4.5-2.5 10.5-2.5 15 0"/>'
} -%}
{%- macro svg(name, color, size) -%}
<svg width="{{size}}" height="{{size}}" viewBox="0 0 24 24" fill="none" stroke="{{color}}" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">{{ ICONS[name]|safe }}</svg>
{%- endmacro -%}
<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ article.title }} | AI・クラウド ニュースダイジェスト</title>
<link rel="icon" href="../static/favicon.svg" type="image/svg+xml">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo:wdth,wght@125,700;125,800&family=IBM+Plex+Mono:wght@400;500;600&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="../static/style.css">
{% if goatcounter %}<script data-goatcounter="{{ goatcounter }}" async src="//gc.zgo.at/count.js"></script>{% endif %}
</head>
<body style="--cat-light:{{ section.accent }};--cat-dark:{{ section.accent_dark }};--hl:{{ section.accent }}26">
<header class="masthead">
  <a class="back-link" href="../index.html">← ダイジェスト一覧へ</a>
</header>

<main class="article-container">
  <div class="article-meta">
    <span class="pill" style="background:{{ section.accent_dark }}">{{ svg(section.icon, '#fff', 12) }}{{ section.name }}</span>
    <span class="article-date">{{ article.published_date }}</span>
  </div>
  <h1 class="article-title">{{ article.title_html }}</h1>

  <div class="three-block">
    <div class="three-block-head">3行でわかる！今日のニュース</div>
    <ul>{% for line in article.three_lines_html %}<li>{{ line }}</li>{% endfor %}</ul>
  </div>

  <div class="summary-pair">
    <p class="sum-ja">{{ article.summary_ja }}</p>
    <p class="sum-en">{{ article.summary_en }}</p>
  </div>

  <div class="article-body">{{ article.body_html }}</div>

  {% if article.references %}
  <div class="references">
    <div class="ref-head">▼ 関連リンク / References</div>
    <ol>
      {% for ref in article.references %}
      <li id="ref-{{ ref.id }}">
        <a href="{{ ref.url }}" target="_blank" rel="noopener noreferrer">{{ ref.title or ref.url }}</a>
        {% if ref.source %}<span class="ref-source">— {{ ref.source }}</span>{% endif %}
      </li>
      {% endfor %}
    </ol>
  </div>
  {% endif %}
</main>

<footer class="foot">本記事は複数の公開情報を基にAIが作成したオリジナルの日本語解説です。引用元の原文は上記リンクをご参照ください。</footer>
</body>
</html>
