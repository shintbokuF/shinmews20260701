<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>過去のダイジェスト | AI・クラウド ニュースダイジェスト</title>
<link rel="stylesheet" href="static/style.css">
</head>
<body>
<header class="site-header">
  <div class="header-inner">
    <h1>過去のダイジェスト</h1>
    <a class="archive-link" href="../index.html">← 最新へ</a>
  </div>
</header>

<main class="container archive-list">
  <ul>
  {% for d in dates %}
    <li><a href="{{ d }}/index.html"><span class="cal">📄</span>{{ d }}</a></li>
  {% endfor %}
  </ul>
  {% if not dates %}<p>まだ記録がありません。</p>{% endif %}
</main>

<footer class="site-footer">
  <p>各日付のスナップショットです。</p>
</footer>
</body>
</html>
